# ============================================================
# KRAMANIK — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Database ──────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_this_root_password
DB_USER=kramanik
DB_PASSWORD=change_this_db_password

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars
JWT_EXPIRATION_MS=86400000

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local dev: http://localhost:5500,http://127.0.0.1:5500
# Production: https://kramanik.netlify.app
CORS_ORIGINS=https://kramanik.netlify.app

# ── Spring ────────────────────────────────────────────────────
SPRING_PROFILE=prod

# ── Frontend (set in frontend/js/config.js) ───────────────────
# Local:      http://localhost:8080
# Production: https://kramanik-backend.railway.app
VITE_API_BASE_URL=https://kramanik-backend.railway.app

# ── RAZORPAY (Sprint 7) ───────────────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── WHATSAPP / WATI (Sprint 8) ────────────────────────────────
# Get from https://wati.io after connecting your WhatsApp Business number
WATI_API_URL=https://live-mt-server.wati.io/api/v1
WATI_API_TOKEN=your_wati_bearer_token
WATI_ENABLED=false
# Set WATI_ENABLED=true once WATI account is connected
